GENERATE_SOURCEMAP=false
ESLINT_NO_DEV_ERRORS=true
TSC_COMPILE_ON_ERROR=true

# Gmail SMTP Configuration
REACT_APP_GMAIL_SMTP_USERNAME=REMOVED_SECRET
REACT_APP_GMAIL_SMTP_PASSWORD=REMOVED_SECRET
REACT_APP_GMAIL_FROM_EMAIL=REMOVED_SECRET
REACT_APP_GMAIL_FROM_NAME=Service Hub
REACT_APP_GMAIL_SMTP_HOST=REMOVED_SECRET
REACT_APP_GMAIL_SMTP_PORT=587

# Server-side SMTP variables (used by Express + Nodemailer)
GMAIL_SMTP_USERNAME=REMOVED_SECRET
GMAIL_SMTP_PASSWORD=REMOVED_SECRET
GMAIL_FROM_EMAIL=REMOVED_SECRET
GMAIL_FROM_NAME=UmmaHub
GMAIL_SMTP_HOST=REMOVED_SECRET
